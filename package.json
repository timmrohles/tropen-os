{
  "name": "tropen-os",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_NO_TURBOPACK=1 next build",
    "security:scan": "gitleaks detect --config .gitleaks.toml --verbose",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint:design": "node scripts/ci/lint-design-system.mjs",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "lint:features": "node scripts/ci/check-feature-guards.mjs",
    "lint:all": "pnpm lint && pnpm lint:design && pnpm lint:deps && pnpm lint:features",
    "analyze": "ANALYZE=true pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.60",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.52",
    "@anthropic-ai/sdk": "^0.80.0",
    "@neondatabase/serverless": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.103.0",
    "@tremor/react": "4.0.0-beta-tremor-v4.4",
    "@types/pg": "^8.18.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.156",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "ignore": "^7.0.5",
    "langsmith": "^0.5.14",
    "next": "^16.2.3",
    "next-intl": "^4.9.1",
    "nodemailer": "^8.0.4",
    "openai": "^6.29.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "rss-parser": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "dependency-cruiser": "^16.10.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "happy-dom": "^20.8.9",
    "msw": "^2.12.14",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
