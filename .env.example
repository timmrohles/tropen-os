# Supabase (öffentlich – sicher für Client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase Service Role – NUR server-seitig (API Routes), nie im Client!
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site URL (für Magic-Link Redirect bei Einladungen)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dify Cloud
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-...
DIFY_JUNGLE_ORDER_KEY=app-...

# OpenAI (für Startseiten-Chat)
OPENAI_API_KEY=sk-...

# LangSmith – LLM Observability (optional, aber empfohlen)
# https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=         # lsv2_...
LANGSMITH_PROJECT=tropen-ai
LANGSMITH_TRACING=true     # false in Tests setzen
