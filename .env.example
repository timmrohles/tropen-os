# Supabase (öffentlich – sicher für Client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase Service Role – NUR server-seitig (API Routes), nie im Client!
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Drizzle ORM – DB-Verbindung (nur für Schema/Migrations-Tooling, nicht für App-Queries)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Site URL (für Magic-Link Redirect bei Einladungen)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend – Inbound Email Webhook
# Zufälliger Secret-String, der als Authorization: Bearer <token> Header mitgeschickt wird
# Resend Dashboard → Inbound → Webhook URL: https://tropen.os/api/feeds/inbound/email?... (Header konfigurieren)
RESEND_INBOUND_SECRET=

# Anthropic – Haupt-KI (Chat, Audit, alle LLM-Calls)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (TTS + Multi-Model Review)
OPENAI_API_KEY=sk-...

# Google Gemini (Multi-Model Review — optional)
GOOGLE_GENERATIVE_AI_API_KEY=

# xAI / Grok (Multi-Model Review — optional)
XAI_API_KEY=

# Upstash Redis – Rate Limiting (optional; ohne diese Vars ist kein Rate Limiting aktiv)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Cron-Schutz – zufälliger Secret-String
# Vercel Cron Jobs senden diesen als Authorization: Bearer <token>
CRON_SECRET=

# Vercel AI Gateway (Multi-Model Review Pipeline — Sprint 4b)
# Option A: API Key (static, manuell rotieren)
AI_GATEWAY_API_KEY=
# Option B: OIDC (automatisch, empfohlen) — nach `vercel env pull .env.local` verfügbar
# VERCEL_OIDC_TOKEN wird automatisch befüllt — kein manueller Eintrag nötig

# Sentry – Error Monitoring (optional, aber empfohlen in Produktion)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/...

# Build-Zeit Variablen (werden von next.config.ts gesetzt — kein manueller Eintrag nötig)
# NEXT_PUBLIC_APP_VERSION=0.1.0
# NEXT_PUBLIC_BUILD_TIME=2026-01-01T00:00:00Z

# Design-Referenz Seite (nur für Entwicklung)
NEXT_PUBLIC_SHOW_DESIGN_REF=false

# GitHub Token (nur für Benchmark-Scripts, nicht für den App-Betrieb)
# GITHUB_TOKEN=ghp_...

# LangSmith – LLM Observability (optional, aber empfohlen)
# https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=         # lsv2_...
LANGSMITH_PROJECT=tropen-ai
LANGSMITH_TRACING=true     # false in Tests setzen
